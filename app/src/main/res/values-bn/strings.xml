    <string name="onboarding_title">আপনার ফোকাস যাত্রায় স্বাগতম!</string>
    <string name="onboarding_desc">প্রতিবার আপনি একটি বিরক্তিকর অ্যাপ খোলার সময়, আপনি ৫-সেকেন্ডের সচেতন বিলম্বের সম্মুখীন হবেন। আপনি যদি \'বাতিল\' চাপেন, আপনি জিতবেন! আপনার মানসিক অ্যাকোয়ারিয়ামে একটি সুন্দর বুদবুদ যোগ করা হবে।</string>
    <string name="onboarding_action">যাত্রা শুরু করুন</string>
    <string name="onboarding_title_1">মানসিক অ্যাকোয়ারিয়াম</string>
    <string name="onboarding_desc_1">বুদবুদ সংগ্রহ করতে ৫-সেকেন্ড বিলম্বের সাথে বিরক্তিকর অ্যাপগুলিকে প্রতিহত করুন!</string>
    <string name="onboarding_title_2">ব্যবহারের সচেতনতা</string>
    <string name="onboarding_desc_2">অ্যাপের বুদবুদগুলি যত বেশি ব্যবহার করা হয় তত বড় হয়, যা আপনার স্ক্রীন টাইম নিয়ন্ত্রণ করতে সাহায্য করে।</string>
    <string name="onboarding_title_3">ফোকাস মোড</string>
    <string name="onboarding_desc_3">প্রয়োজনীয় অ্যাপ নির্বাচন করুন এবং সমস্ত বিভ্রান্তি লুকাতে ফোকাস মোড চালু করুন।</string>
    <string name="onboarding_title_4">সম্পূর্ণ নিয়ন্ত্রণ</string>
